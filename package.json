{
  "name": "dorianmintbotv2",
  "private": true,
  "version": "0.1.0",
  "description": "Dorian Mint Bot V2",
  "main": "electron/main.js",
  "type": "module",

  "scripts": {
    "dev": "vite",

    "electron": "electron electron/main.js",

    "electron:dev": "concurrently -k \"vite --strictPort\" \"wait-on http://127.0.0.1:5173 && electron electron/main.js\"",

    "build": "vite build",

    "electron:build": "vite build && electron-builder",

    "preview": "vite preview",

    "lint": "eslint ."
  },

  "build": {
    "appId": "com.dorian.mintbot",
    "productName": "Dorian Mint Bot V2",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis"
    }
  },

  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^11.0.2",
    "ethers": "^6.17.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sqlite3": "^6.0.1"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}