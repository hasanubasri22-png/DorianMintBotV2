{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dorianmintbotv2",
  "private": true,
  "version": "1.0.0",
  "description": "Dorian Mint Bot V2 - HD Wallet Manager & Batch Transaction Tool",
  "type": "module",
  "main": "electron/main.js",
  "author": "Dorian",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron": "electron electron/main.js",
    "electron:dev": "concurrently -k \"vite --strictPort\" \"wait-on http://127.0.0.1:5173 && electron electron/main.js\"",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint ."
  },
  "build": {
    "appId": "com.dorian.mintbot",
    "productName": "Dorian Mint Bot V2",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "certificateFile": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chart.js": "^4.4.0",
    "crypto-js": "^4.2.0",
    "ethers": "^6.10.0",
    "lucide-react": "^1.292.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^14.0.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
